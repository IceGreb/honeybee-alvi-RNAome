nextflow.enable.dsl = 2

profiles {
    cambridge {
        includeConfig 'cambridge.config'
    }
    local {
        process.executor = 'local'
        process {
            withLabel: 'count_only' { cpus = 2; memory = 4.GB }
            withLabel: 'low'        { cpus = 2; memory = 4.GB }
            withLabel: 'med'        { cpus = 4; memory = 8.GB }
            withLabel: 'high'       { cpus = 4; memory = 8.GB }
        }
    }
}

// Work directory for intermediate files. Override here or pass -work-dir on the command line.
// On HPC systems, point this outside your home quota (e.g. a scratch or RDS path).
// workDir = '<path/to/work/directory>'

// 'lenient' prevents spurious cache misses from NFS timestamp jitter on RDS
process.cache = 'lenient'

// Static filenames (def declarations not allowed at top level in Nextflow 26.x)
report   { enabled = true; file = "pipeline_reports/report.html";    overwrite = true }
timeline { enabled = true; file = "pipeline_reports/timeline.html";  overwrite = true }
dag      { enabled = true; file = "pipeline_reports/dag.html";       overwrite = true; direction = 'LR' }
trace    { enabled = true; file = "pipeline_reports/trace.tsv";      overwrite = true
           fields = 'task_id,name,tag,status,exit,realtime,%cpu,rss,peak_rss,rchar,wchar' }

manifest {
    name        = 'transRNA-pipeline'
    version     = '1.2'
    description = 'Paired-end transRNA identification and filtering pipeline'
    author      = 'Nikolaos Vergoulidis'
    nextflowVersion = '>=24.04'
}

