/*
================================================================================
  cambridge.config  —  Cambridge HPC (CSD3) profile
  Adapted from the user's nf-core Cambridge profile.
================================================================================
*/

params {
    config_profile_description = 'Cambridge HPC cluster profile (CSD3).'
    config_profile_url         = "https://docs.hpc.cam.ac.uk/hpc"

    // Set on the command line via run.sh:  --partition icelake  --project MAORI-SL2-CPU
    partition  = null
    project    = null

    max_memory = 192.GB
    max_cpus   = 56
    max_time   = 12.h

    tmpdir = "<path/to/tmp/directory>"
}

singularity {
    enabled    = true
    autoMounts = true
    runOptions = "-B ${params.tmpdir}:/tmp"
}

process {
    resourceLimits = [
        memory: 192.GB,
        cpus:   56,
        time:   12.h
    ]
    executor       = 'slurm'
    clusterOptions = "-A ${params.project} -p ${params.partition}"

    // ── Resource labels ───────────────────────────────────────────────────────
    withLabel: 'count_only' {
        cpus   = 2
        memory = 8.GB
        time   = 1.h
    }
    withLabel: 'low' {
        cpus   = 4
        memory = 16.GB
        time   = 2.h
    }
    withLabel: 'med' {
        cpus   = 8
        memory = 32.GB
        time   = 6.h
    }
    withLabel: 'high' {
        cpus   = 16
        memory = 64.GB
        time   = 12.h
    }

    // ── Per-process overrides ─────────────────────────────────────────────────
    withName: 'COLLAPSE_READS' {
        // seqkit rmdup on large .fq can need significant memory
        cpus   = 8
        memory = 48.GB
        time   = 4.h
    }
    withName: 'ANNOTATE_KRAKEN' {
        cpus   = 4
        memory = 24.GB
        time   = 4.h
    }
    withName: 'ANNOTATE_BLAST' {
        // BLAST TSVs can be ~500 MB each; taxonkit subprocess is memory-hungry
        cpus   = 4
        memory = 64.GB
        time   = 6.h
    }
    withName: 'TAXONOMY_PARSER' {
        // Runs once globally across all samples
        cpus   = 4
        memory = 32.GB
        time   = 4.h
    }

    // ── Retry on transient HPC / RDS I/O errors ───────────────────────────────
    errorStrategy = { task.exitStatus in [130, 137, 140, 143] ? 'retry' : 'finish' }
    maxRetries    = 2

    // ── Activate mamba/conda environment in every SLURM job ──────────────────
    // Find your env path with: conda info --envs
    // Find your conda base with: conda info --base  (append /etc/profile.d/conda.sh)
    beforeScript = """
        export PATH=<path/to/conda/env/bin>:\$PATH
    """
}

